{
  "name": "voice-relay",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time text/speech relay between browser devices",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "generate:changelog": "npx tsx scripts/generate-changelog.ts",
    "prebuild": "npm run generate:changelog",
    "build": "npm run build -w client && npm run build -w server",
    "start": "npm run start -w server",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:mobile": "playwright test --project=mobile-chrome tests/mobile-voice.spec.ts",
    "test:mobile:headed": "playwright test --project=mobile-chrome tests/mobile-voice.spec.ts --headed",
    "test:mobile:real": "RUN_REAL_SPEECH_TESTS=1 playwright test --project=mobile-chrome tests/mobile-voice.spec.ts --headed",
    "smoke": "playwright test --config=tests/smoke/playwright.config.ts",
    "smoke:auth": "playwright test --config=tests/smoke/playwright.config.ts --headed",
    "clean": "rm -rf node_modules server/node_modules server/dist client/node_modules client/dist",
    "db:status": "npm run db:status -w server",
    "db:migrate": "npm run db:migrate -w server",
    "db:rollback": "npm run db:rollback -w server --",
    "db:new": "npm run db:new -w server --"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^8.2.2"
  }
}
