# Voice Relay Environment Configuration
# Copy to .env and fill in real values

# Server
PORT=3002
BASE_URL=https://vr.chorecraft.net

# Storage
STORE_DRIVER=sqlite
SQLITE_PATH=/var/www/vr.chorecraft.net/app/data/messages.db

# GitHub OAuth (create app at https://github.com/settings/developers)
# Callback URL should be: ${BASE_URL}/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# JWT Authentication
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# OpenHands Integration (optional)
OPENHANDS_CLOUD_API_KEY=your_openhands_api_key
