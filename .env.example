# Voice Relay Environment Configuration
# Copy to .env and fill in real values

# Server
PORT=3002
BASE_URL=https://app.no-hands.dev

# Storage
STORE_DRIVER=sqlite
SQLITE_PATH=./data/messages.db

# GitHub App (create app at https://github.com/settings/apps/new)
# Enable "Request user authorization (OAuth) during installation" and set the
# User authorization callback URL to: ${BASE_URL}/auth/github/callback
# GITHUB_APP_SLUG is the slug from the App URL, e.g. for
# https://github.com/apps/no-hands-agent-screencast it's `no-hands-agent-screencast`.
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_APP_SLUG=your_github_app_slug

# JWT Authentication
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# OpenHands Integration (optional)
OPENHANDS_CLOUD_API_KEY=your_openhands_api_key

# Test Authentication (optional - for CI smoke tests)
# Generate with: openssl rand -hex 32
# When set, enables POST /auth/test-session endpoint
TEST_AUTH_SECRET=your_test_auth_secret

# Hosted STT (issue #386) — optional
# When a workspace opts in to Deepgram via the workspace settings UI, the
# server brokers short-lived (<=60s) Deepgram API keys to the kiosk so it
# can stream directly to the Deepgram /v1/listen endpoint without the
# relay ever seeing audio. The long-lived API key is stored per-workspace
# (encrypted with the same ENCRYPTION_SECRET used for ElevenLabs / OpenHands
# keys), so there are no global env vars for the key itself.
#
# Optional override for the Deepgram base URL — only set if you're
# pointing at a staging or regional Deepgram deployment. Defaults to
# https://api.deepgram.com.
# DEEPGRAM_BASE_URL=https://api.deepgram.com
